<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Parachute — NVC Pitch Deck</title>
    <meta name="robots" content="noindex">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,400&family=JetBrains+Mono:wght@400&display=swap">
    <style>
        :root {
            --bg:           #faf8f4;
            --bg-soft:      #f3f0ea;
            --fg:           #2c2a26;
            --fg-muted:     #6b6860;
            --fg-dim:       #9a9690;
            --accent:       #4a7c59;
            --accent-soft:  rgba(74, 124, 89, 0.08);
            --accent-light: #6a9b77;
            --border:       #e4e0d8;
            --serif: 'Instrument Serif', Georgia, serif;
            --sans:  'DM Sans', system-ui, sans-serif;
            --mono:  'JetBrains Mono', monospace;
        }

        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; scroll-snap-type: y mandatory; }

        body {
            background: var(--bg);
            font-family: var(--sans);
            color: var(--fg);
            -webkit-font-smoothing: antialiased;
            line-height: 1.6;
        }

        /* ── Slide structure ── */
        .slide {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 4rem 6rem;
            border-bottom: 1px solid var(--border);
            scroll-snap-align: start;
            position: relative;
        }
        .slide:last-child { border-bottom: none; }

        .slide-label {
            font-size: 0.65rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--accent);
            font-weight: 500;
            margin-bottom: 1.5rem;
        }

        .slide-headline {
            font-family: var(--serif);
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 400;
            letter-spacing: -0.02em;
            line-height: 1.08;
            color: var(--fg);
            margin-bottom: 2rem;
        }
        .slide-headline em {
            font-style: italic;
            color: var(--fg-muted);
        }

        .slide-body {
            color: var(--fg-muted);
            max-width: 720px;
        }
        .slide-body p {
            font-size: 1.15rem;
            line-height: 1.7;
            margin-bottom: 1rem;
        }
        .slide-body p:last-child { margin-bottom: 0; }
        .slide-body strong { color: var(--fg); font-weight: 500; }

        /* ── Stat row ── */
        .stat-row {
            display: flex;
            gap: 0;
            margin: 1.5rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 500px;
        }
        .stat {
            flex: 1;
            padding: 1.5rem;
            border-right: 1px solid var(--border);
            text-align: center;
        }
        .stat:last-child { border-right: none; }
        .stat-num {
            font-family: var(--serif);
            font-size: 2.5rem;
            color: var(--accent);
            line-height: 1;
            letter-spacing: -0.03em;
            margin-bottom: 0.4rem;
        }
        .stat-label {
            font-size: 0.75rem;
            color: var(--fg-muted);
            line-height: 1.4;
        }

        /* ── People list ── */
        .people {
            font-family: var(--serif);
            font-size: 1.3rem;
            line-height: 2.2;
            color: var(--fg-muted);
            max-width: 600px;
        }
        .people em { font-style: italic; color: var(--fg); }

        /* ── Flywheel ── */
        .flywheel {
            display: flex;
            flex-direction: column;
            max-width: 500px;
            margin: 1rem 0;
        }
        .fw-step {
            font-family: var(--serif);
            font-size: 1.35rem;
            color: var(--fg);
            padding: 0.85rem 0;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .fw-step:first-child { border-top: 1px solid var(--border); }
        .fw-step.final { color: var(--accent); }
        .fw-num {
            font-family: var(--mono);
            font-size: 0.65rem;
            color: var(--fg-dim);
            letter-spacing: 0.06em;
            flex-shrink: 0;
            width: 1.5rem;
        }

        /* ── Bullet list ── */
        .bullet-list {
            list-style: none;
            padding: 0;
            margin: 0.5rem 0;
            max-width: 650px;
        }
        .bullet-list li {
            font-size: 1.1rem;
            color: var(--fg-muted);
            padding: 0.5rem 0 0.5rem 1.5rem;
            position: relative;
        }
        .bullet-list li::before {
            content: "·";
            position: absolute;
            left: 0.25rem;
            color: var(--accent);
            font-weight: bold;
        }

        /* ── Tier table ── */
        .tier-table {
            margin: 1rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 600px;
        }
        .tier-row {
            display: flex;
            align-items: baseline;
            gap: 1.25rem;
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border);
        }
        .tier-row:last-child { border-bottom: none; }
        .tier-price {
            font-family: var(--serif);
            font-size: 1.5rem;
            color: var(--accent);
            min-width: 5rem;
            flex-shrink: 0;
        }
        .tier-price span { font-family: var(--sans); font-size: 0.75rem; color: var(--fg-dim); }
        .tier-body { font-size: 0.9rem; color: var(--fg-muted); }
        .tier-body strong { color: var(--fg); font-weight: 500; }
        .tier-highlight { background: var(--accent-soft); }

        /* ── Pendant callout ── */
        .pendant-callout {
            background: var(--bg-soft);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 1.75rem;
            max-width: 340px;
            position: absolute;
            right: 6rem;
            top: 50%;
            transform: translateY(-50%);
        }
        .pendant-callout .label {
            font-size: 0.65rem;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: var(--accent);
            font-weight: 500;
            margin-bottom: 0.75rem;
        }
        .pendant-callout p {
            font-size: 0.95rem;
            color: var(--fg-muted);
            line-height: 1.6;
        }

        /* ── Financial table ── */
        .fin-table {
            margin: 1rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 700px;
        }
        .fin-table table {
            width: 100%;
            border-collapse: collapse;
        }
        .fin-table th {
            font-size: 0.7rem;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: var(--fg-dim);
            font-weight: 500;
            text-align: center;
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border);
            background: var(--bg-soft);
        }
        .fin-table th:first-child { text-align: left; }
        .fin-table td {
            font-size: 0.9rem;
            color: var(--fg-muted);
            padding: 0.65rem 1rem;
            border-bottom: 1px solid var(--border);
            text-align: center;
        }
        .fin-table td:first-child {
            font-weight: 500;
            color: var(--fg);
            text-align: left;
            font-size: 0.85rem;
        }
        .fin-table tr:last-child td { border-bottom: none; }
        .fin-table .highlight { color: var(--accent); font-weight: 500; }

        /* ── Ask box ── */
        .ask-box {
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            margin: 1rem 0;
            max-width: 500px;
        }
        .ask-row {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            padding: 0.9rem 1.25rem;
            border-bottom: 1px solid var(--border);
        }
        .ask-row:last-child { border-bottom: none; }
        .ask-row .lbl { font-size: 0.85rem; color: var(--fg-muted); }
        .ask-row .val { font-family: var(--serif); font-size: 1.1rem; color: var(--fg); }

        .close-quote {
            font-family: var(--serif);
            font-size: clamp(1.5rem, 3vw, 2rem);
            color: var(--fg);
            margin-top: 2.5rem;
            line-height: 1.3;
            max-width: 550px;
        }
        .close-links {
            margin-top: 1.5rem;
            font-size: 0.85rem;
            color: var(--fg-dim);
        }
        .close-links a {
            color: var(--accent);
            text-decoration: none;
        }
        .close-links a:hover { text-decoration: underline; }

        /* ── Architecture diagram ── */
        .arch-diagram {
            margin: 1.5rem 0;
            border: 1px solid var(--border);
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            max-width: 650px;
            padding: 2rem 2.5rem;
        }
        .arch-row {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .arch-label {
            font-family: var(--mono);
            font-size: 0.7rem;
            letter-spacing: 0.04em;
            color: var(--fg-dim);
            min-width: 6rem;
            text-align: right;
            flex-shrink: 0;
        }
        .arch-box {
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.5rem 1rem;
            font-size: 0.85rem;
            color: var(--fg);
            background: var(--bg);
        }
        .arch-box.accent {
            border-color: var(--accent);
            background: var(--accent-soft);
            color: var(--accent);
            font-weight: 500;
        }
        .arch-arrow {
            font-family: var(--mono);
            font-size: 0.7rem;
            color: var(--fg-dim);
            text-align: center;
            padding: 0.3rem 0;
            margin-left: 6rem;
            padding-left: 1rem;
        }

        /* ── Mobile ── */
        @media (max-width: 768px) {
            .slide { padding: 3rem 1.5rem; }
            .pendant-callout {
                position: static;
                transform: none;
                margin-top: 1.5rem;
                max-width: 100%;
            }
            .stat-row { flex-direction: column; }
            .stat { border-right: none; border-bottom: 1px solid var(--border); }
            .stat:last-child { border-bottom: none; }
        }
    </style>
</head>
